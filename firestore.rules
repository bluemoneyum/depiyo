rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow write: if true; 
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    // Experiences collection
    match /experiences/{experienceId} {
      allow read: if true;
      allow write: if true;
    }

    // Messages collection
    match /messages/{messageId} {
      allow create: if true;
      allow read, delete: if true; // In production, these should be restricted to admin
    }
  }
}
